# Elecraft KPOD - allow non-root access to the USB HID device
SUBSYSTEM=="hidraw", ATTRS{idVendor}=="04d8", ATTRS{idProduct}=="f12d", MODE="0666"

# Elecraft KPOD+ - allow non-root access to the USB vendor-specific class device
# Same VID/PID as KPOD but uses bInterfaceClass=255 (vendor-specific) instead of HID
SUBSYSTEM=="usb", ATTR{idVendor}=="04d8", ATTR{idProduct}=="f12d", MODE="0666"

# Elecraft KPOD+ - future Elecraft PID
SUBSYSTEM=="usb", ATTR{idVendor}=="04d8", ATTR{idProduct}=="efa5", MODE="0666"
SUBSYSTEM=="hidraw", ATTRS{idVendor}=="04d8", ATTRS{idProduct}=="efa5", MODE="0666"
